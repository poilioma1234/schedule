@model schedule.Models.TaskItem

@{
    ViewData["Title"] = "Sửa task";
}

<div class="page-heading">
    <div>
        <h1>Sửa task</h1>
        <p class="text-muted mb-0">@Model.ScheduleItem?.Title</p>
    </div>
    <a class="btn btn-outline-secondary" asp-controller="Schedule" asp-action="Edit" asp-route-id="@Model.ScheduleItemId">Quay lại lịch</a>
</div>

<div class="form-card">
    <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
        <partial name="_Form" model="Model" />
        <div class="mt-4 d-flex gap-2">
            <button type="submit" class="btn btn-primary">Cập nhật task</button>
            <a class="btn btn-outline-secondary" asp-controller="Schedule" asp-action="Edit" asp-route-id="@Model.ScheduleItemId">Hủy</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
