@model schedule.Models.ScheduleItem
@using schedule.Helpers
@using schedule.Models

@{
    ViewData["Title"] = "Sửa lịch";
    var newTask = new TaskItem
    {
        ScheduleItemId = Model.Id,
        Deadline = Model.EndTime,
        Priority = TaskPriorityLevel.Medium,
        Status = TaskItemStatus.NotStarted,
        Color = TaskDisplayHelper.PriorityColor(TaskPriorityLevel.Medium)
    };
}

<div class="page-heading">
    <div>
        <h1>Sửa lịch</h1>
        <p class="text-muted mb-0">Quản lý thông tin lịch và các task/deadline bên trong.</p>
    </div>
    <a class="btn btn-outline-secondary" asp-action="Index">Quay lại</a>
</div>

@if (TempData["TaskError"] != null)
{
    <div class="alert alert-danger">@TempData["TaskError"]</div>
}

<div class="form-card mb-4">
    <form asp-action="Edit" method="post">
        <input type="hidden" asp-for="Id" />
        <partial name="_Form" model="Model" />
        <div class="mt-4 d-flex gap-2">
            <button type="submit" class="btn btn-primary">Cập nhật</button>
            <a class="btn btn-outline-secondary" asp-action="Index">Hủy</a>
        </div>
    </form>
</div>

<section class="task-board">
    <div class="panel-section">
        <div class="section-title">
            <h2>Task trong lịch</h2>
            <span class="text-muted">@Model.Tasks.Count task</span>
        </div>

        @if (Model.Tasks.Any())
        {
            <div class="task-list">
                @foreach (var task in Model.Tasks.OrderBy(task => task.Deadline))
                {
                    var effectiveStatus = TaskDisplayHelper.EffectiveStatus(task, DateTime.Now);
                    <article class="task-card @(effectiveStatus == TaskItemStatus.Overdue ? "is-overdue" : "")" style="border-left-color:@task.Color">
                        <div>
                            <div class="task-title-row">
                                <strong>@task.Title</strong>
                                <span class="task-badge">@TaskDisplayHelper.StatusText(effectiveStatus)</span>
                            </div>
                            @if (!string.IsNullOrWhiteSpace(task.Description))
                            {
                                <p>@task.Description</p>
                            }
                            <div class="task-meta">
                                <span>Deadline: @task.Deadline.ToString("dd/MM/yyyy HH:mm")</span>
                                <span>Ưu tiên: @TaskDisplayHelper.PriorityText(task.Priority)</span>
                                @if (!string.IsNullOrWhiteSpace(task.AttachmentUrl))
                                {
                                    <a href="@task.AttachmentUrl" target="_blank" rel="noopener">Link đính kèm</a>
                                }
                            </div>
                        </div>
                        <div class="task-actions">
                            <a class="btn btn-sm btn-outline-primary" asp-controller="Tasks" asp-action="Edit" asp-route-id="@task.Id">Sửa</a>
                            <a class="btn btn-sm btn-outline-danger" asp-controller="Tasks" asp-action="Delete" asp-route-id="@task.Id">Xóa</a>
                        </div>
                    </article>
                }
            </div>
        }
        else
        {
            <div class="empty-state compact">
                <h3>Chưa có task nào</h3>
                <p>Thêm task để chia lịch này thành các việc nhỏ, có deadline và mức độ ưu tiên rõ ràng.</p>
            </div>
        }
    </div>

    <div class="panel-section">
        <h2>Thêm task nhanh</h2>
        <form asp-controller="Tasks" asp-action="Create" method="post">
            <partial name="~/Views/Tasks/_Form.cshtml" model="newTask" />
            <button class="btn btn-primary w-100 mt-4" type="submit">Thêm task</button>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
