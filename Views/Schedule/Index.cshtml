@model IEnumerable<schedule.Models.ScheduleItem>
@using schedule.Models

@functions {
    private static string TimeAgo(DateTime createdAt)
    {
        var span = DateTime.Now - createdAt;

        if (span.TotalDays >= 1)
        {
            var days = (int)Math.Floor(span.TotalDays);
            return days == 1 ? "1 ngày trước" : $"{days} ngày trước";
        }

        if (span.TotalHours >= 1)
        {
            var hours = (int)Math.Floor(span.TotalHours);
            return hours == 1 ? "1 giờ trước" : $"{hours} giờ trước";
        }

        if (span.TotalMinutes >= 1)
        {
            var minutes = (int)Math.Floor(span.TotalMinutes);
            return minutes == 1 ? "1 phút trước" : $"{minutes} phút trước";
        }

        return "Vừa xong";
    }
}

@{
    ViewData["Title"] = "Lịch trình";
    var isAdminViewingUser = User.IsInRole("Admin") && ViewBag.ViewingUserEmail != null;
}

<div class="page-heading">
    <div>
        <h1>Lịch trình</h1>
        <p class="text-muted mb-0">Đang xem: @ViewBag.ViewingUserEmail</p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        @if (User.IsInRole("Admin"))
        {
            <a class="btn btn-outline-secondary" asp-controller="Admin" asp-action="Index">Quay lại Admin</a>
        }
        <a class="btn btn-outline-primary" asp-action="Calendar" asp-route-userId="@ViewBag.ViewingUserId">Calendar</a>
        <a class="btn btn-outline-danger" asp-action="ExportPdf" asp-route-userId="@ViewBag.ViewingUserId">Xuất PDF</a>
        @if (!User.IsInRole("Admin") || !isAdminViewingUser)
        {
            <a class="btn btn-primary" asp-action="Create">Thêm lịch</a>
        }
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
}

<form method="get" class="toolbar-panel mb-3">
    <input type="hidden" name="userId" value="@ViewBag.ViewingUserId" />
    <div>
        <label class="form-label">Tìm theo tiêu đề</label>
        <input class="form-control" type="text" name="searchString" value="@ViewBag.SearchString" />
    </div>
    <div>
        <label class="form-label">Ngày bắt đầu</label>
        <input class="form-control" type="date" name="startDate" value="@ViewBag.StartDate" />
    </div>
    <div class="align-self-end d-flex gap-2">
        <button class="btn btn-primary" type="submit">Lọc</button>
        <a class="btn btn-outline-secondary" asp-action="Index" asp-route-userId="@ViewBag.ViewingUserId">Đặt lại</a>
    </div>
</form>

<div class="table-responsive">
    <table class="table align-middle table-hover">
        <thead>
            <tr>
                <th>Tiêu đề</th>
                <th>Bắt đầu</th>
                <th>Kết thúc</th>
                <th>Ngày tạo</th>
                <th>Địa điểm</th>
                <th>Task</th>
                <th>Người tạo</th>
                <th>Nhắc email</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                var hasOverdueTask = item.Tasks.Any(task => task.Status != TaskItemStatus.Completed && task.Deadline < DateTime.Now);
                var canEditToday = item.StartTime.Date == DateTime.Today;
                <tr class="@(item.IsImportant || hasOverdueTask ? "table-danger" : "")">
                    <td>
                        <strong>@item.Title</strong>
                        @if (!string.IsNullOrWhiteSpace(item.Description))
                        {
                            <div class="text-muted small">@item.Description</div>
                        }
                    </td>
                    <td>@item.StartTime.ToString("dd/MM/yyyy HH:mm")</td>
                    <td>@item.EndTime.ToString("dd/MM/yyyy HH:mm")</td>
                    <td>
                        @item.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                        <div class="text-muted small">@TimeAgo(item.CreatedAt)</div>
                    </td>
                    <td>@item.Location</td>
                    <td>
                        <strong>@item.Tasks.Count</strong>
                        @if (hasOverdueTask)
                        {
                            <div class="text-danger small">Có task quá hạn</div>
                        }
                    </td>
                    <td>@item.CreatedByEmail</td>
                    <td>
                        @if (!string.IsNullOrWhiteSpace(item.ReceiverEmail))
                        {
                            <span>@item.ReceiverEmail</span>
                            <div class="text-muted small">Trước @item.ReminderMinutes phút</div>
                        }
                    </td>
                    <td class="text-end">
                        @if (canEditToday)
                        {
                            <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@item.Id">Sửa</a>
                        }
                        <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@item.Id">Xóa</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
