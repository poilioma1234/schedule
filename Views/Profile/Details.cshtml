@model schedule.ViewModels.ProfileViewModel
@using System.Text.Json

@{
    ViewData["Title"] = Model.Profile.DisplayName;
    var avatar = string.IsNullOrWhiteSpace(Model.Profile.AvatarPath) ? null : Model.Profile.AvatarPath;
    var cover = string.IsNullOrWhiteSpace(Model.Profile.CoverPath) ? null : Model.Profile.CoverPath;
    var avatarLetter = string.IsNullOrWhiteSpace(Model.Profile.DisplayName)
        ? "U"
        : Model.Profile.DisplayName.Substring(0, 1).ToUpper();
    var completedTaskChart = JsonSerializer.Serialize(Model.CompletedTaskChart);
}

@if (TempData["ProfileMessage"] != null)
{
    <div class="alert alert-success">@TempData["ProfileMessage"]</div>
}

@if (Model.IsLocked)
{
    <div class="alert alert-danger profile-lock-alert">
        <strong>User bị khóa</strong>
        <span>Tài khoản này đang bị admin khóa, nên không tham gia bảng xếp hạng.</span>
    </div>
}

<section class="profile-cover" style="@(cover != null ? $"background-image: linear-gradient(rgba(15, 23, 42, .25), rgba(15, 23, 42, .25)), url('{cover}')" : "")">
    <div class="profile-cover-content">
        <div class="profile-identity">
            <div class="profile-avatar">
                @if (avatar != null)
                {
                    <img src="@avatar" alt="Ảnh đại diện của @Model.Profile.DisplayName" />
                }
                else
                {
                    <span>@avatarLetter</span>
                }
            </div>
            <div>
                <p class="eyebrow">Hồ sơ người dùng</p>
                <h1>@Model.Profile.DisplayName</h1>
                <p>@Model.Email</p>
                @if (Model.IsPublicProfile)
                {
                    <small class="profile-public-url">@Model.PublicProfilePath</small>
                }
                @if (Model.IsOwner && !Model.Profile.IsProfilePublic)
                {
                    <small class="profile-public-url">Profile đang tắt công khai và không tham gia bảng xếp hạng.</small>
                }
            </div>
        </div>

        @if (Model.IsOwner)
        {
            <div class="profile-owner-actions">
                <a class="btn btn-light" asp-action="Edit">Chỉnh sửa hồ sơ</a>
                <a class="btn btn-outline-light" href="@Model.PublicProfilePath">Xem trang public</a>
            </div>
        }
    </div>
</section>

<section class="profile-grid">
    <div class="profile-main">
        <div class="panel-section">
            <h2>Giới thiệu</h2>
            @if (!string.IsNullOrWhiteSpace(Model.Profile.Bio))
            {
                <p class="profile-bio">@Model.Profile.Bio</p>
            }
            else
            {
                <p class="text-muted">Người dùng chưa viết giới thiệu.</p>
            }
        </div>

        <div class="panel-section">
            <h2>Hoạt động</h2>
            <div class="profile-activity-summary">
                <div>
                    <span>Tổng task</span>
                    <strong>@Model.TotalTasks</strong>
                </div>
                <div>
                    <span>Hoàn thành</span>
                    <strong>@Model.CompletedTaskCount</strong>
                </div>
                <div>
                    <span>Chuỗi hiện tại</span>
                    <strong>@Model.CurrentStreakDays</strong>
                </div>
                <div>
                    <span>Chuỗi dài nhất</span>
                    <strong>@Model.LongestStreakDays</strong>
                </div>
            </div>
            <div class="profile-chart-frame">
                <canvas id="profileCompletedTasksChart"></canvas>
            </div>
        </div>

        <div class="panel-section">
            <h2>Liên kết</h2>
            <div class="profile-links">
                @if (!string.IsNullOrWhiteSpace(Model.Profile.FacebookUrl))
                {
                    <a href="@Model.Profile.FacebookUrl" target="_blank" rel="noopener">Facebook</a>
                }
                @if (!string.IsNullOrWhiteSpace(Model.Profile.YouTubeUrl))
                {
                    <a href="@Model.Profile.YouTubeUrl" target="_blank" rel="noopener">YouTube</a>
                }
                @if (!string.IsNullOrWhiteSpace(Model.Profile.TikTokUrl))
                {
                    <a href="@Model.Profile.TikTokUrl" target="_blank" rel="noopener">TikTok</a>
                }
                @if (!string.IsNullOrWhiteSpace(Model.Profile.WebsiteUrl))
                {
                    <a href="@Model.Profile.WebsiteUrl" target="_blank" rel="noopener">Website</a>
                }
                @if (string.IsNullOrWhiteSpace(Model.Profile.FacebookUrl)
                    && string.IsNullOrWhiteSpace(Model.Profile.YouTubeUrl)
                    && string.IsNullOrWhiteSpace(Model.Profile.TikTokUrl)
                    && string.IsNullOrWhiteSpace(Model.Profile.WebsiteUrl))
                {
                    <span class="text-muted">Chưa có liên kết công khai.</span>
                }
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.Profile.MusicUrl))
        {
            <div class="panel-section">
                <h2>Nhạc trong profile</h2>
                @if (Model.ShouldAutoplayMusic && !string.IsNullOrWhiteSpace(Model.YouTubeEmbedUrl))
                {
                    <div class="profile-music-player">
                        <iframe src="@Model.YouTubeEmbedUrl"
                                title="Nhạc trong profile"
                                allow="autoplay; encrypted-media; picture-in-picture"
                                allowfullscreen></iframe>
                    </div>
                }
                else
                {
                    <a href="@Model.Profile.MusicUrl" target="_blank" rel="noopener">@Model.Profile.MusicUrl</a>
                }
            </div>
        }
    </div>

    <aside class="profile-side">
        <div class="profile-stat-card">
            <span>Tổng lịch</span>
            <strong>@Model.TotalSchedules</strong>
        </div>
        <div class="profile-stat-card">
            <span>Lịch hôm nay</span>
            <strong>@Model.TodaySchedules</strong>
        </div>
        <div class="profile-stat-card">
            <span>Lịch quan trọng</span>
            <strong>@Model.ImportantSchedules</strong>
        </div>
        <div class="profile-stat-card">
            <span>Đang/sắp diễn ra</span>
            <strong>@Model.ActiveOrUpcomingSchedules</strong>
        </div>
        <div class="profile-stat-card">
            <span>Tổng task</span>
            <strong>@Model.TotalTasks</strong>
        </div>
        <div class="profile-stat-card muted">
            <span>Task hoàn thành</span>
            <strong>@Model.CompletedTaskCount</strong>
            <small>Tính từ các task đã đánh dấu hoàn thành.</small>
        </div>
        <div class="profile-stat-card muted">
            <span>Task quá hạn</span>
            <strong>@Model.OverdueTaskCount</strong>
        </div>
        <div class="profile-stat-card muted">
            <span>Chuỗi hiện tại</span>
            <strong>@Model.CurrentStreakDays ngày</strong>
        </div>
        <div class="profile-stat-card muted">
            <span>Chuỗi dài nhất</span>
            <strong>@Model.LongestStreakDays ngày</strong>
        </div>
        <div class="profile-stat-card muted">
            <span>Thứ hạng</span>
            <strong>@Model.RankLabel</strong>
        </div>
    </aside>
</section>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>
    <script>
        const profileCompletedTaskChart = @Html.Raw(completedTaskChart);
        const profileCanvas = document.getElementById('profileCompletedTasksChart');

        if (profileCanvas && window.Chart) {
            new Chart(profileCanvas, {
                type: 'line',
                data: {
                    labels: profileCompletedTaskChart.Labels,
                    datasets: [{
                        label: profileCompletedTaskChart.Title,
                        data: profileCompletedTaskChart.Values,
                        borderColor: profileCompletedTaskChart.Color,
                        backgroundColor: `${profileCompletedTaskChart.Color}22`,
                        borderWidth: 2,
                        fill: true,
                        tension: 0.35
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false }
                    },
                    scales: {
                        x: { grid: { display: false } },
                        y: {
                            beginAtZero: true,
                            ticks: { precision: 0 }
                        }
                    }
                }
            });
        }
    </script>
}
